# === REBASE NOTES (for AI agents maintaining this patch) ===
# Pinned goose revision: 9626b4c3c143ffc390cf40b4cbd314d2e318d3e2 (npins.ai.goose)
#
# Symptom: `goose run -t hello` against the jw-codex OpenAI-compatible proxy
# (https://ai901.site) errors with
#   Network error: Stream decode error: Failed to parse Responses stream event:
#   missing field `id`: "{...,\"type\":\"response.completed\",...}"
# even though the text deltas parsed fine and the response is otherwise complete.
#
# Root cause: the OpenAI Responses API schema in goose's
# crates/goose/src/providers/formats/openai_responses.rs declares
# `ResponseOutputItemInfo::Message { id: String, status: String, ... }` and the
# same for FunctionCall, all without `#[serde(default)]`. The jw-codex (and
# likely other OpenAI-compatible relays) emit the final `response.completed`
# event with `response.output[]` items stripped to just
#   {"type":"message","role":"assistant","content":[...]}
# omitting `id` and `status` - but the same items are present in full
# (with id/status) in the earlier `response.output_item.done` events. The
# pre-existing responses-output-item-defaults.patch only made `sequence_number`
# optional; it did not touch the `ResponseOutputItemInfo` variants, so the
# `response.completed` deserialization still fails.
#
# Fix: add `#[serde(default)]` to the `id`, `status`, `name`, and `arguments`
# fields of the `Message` and `FunctionCall` variants so the parser tolerates
# stripped-down items. Defaults are empty strings, which is safe because
# `process_streaming_output_items` does not use `Message.id`/`status` at all,
# and `FunctionCall` is only consumed for tool calls where every non-test proxy
# populates these fields. When `response.completed` arrives with stripped
# items, the consumer falls back to the `output_items` already accumulated from
# the earlier `OutputItemDone` events (see
# `responses_api_to_streaming_message` in the same file).
#
# Stacking order (see ./package.nix):
#   1. responses-output-item-defaults.patch (sequence_number defaults)
#   2. this patch (output-item field defaults)
# This patch is generated against the *stacked* source state, not raw upstream.
#
# Re-test by running:
#   curl -sN -X POST "$(yq .base_url ~/.config/goose/custom_providers/jw-codex.json)/v1/responses" \
#     -H "Authorization: Bearer $JW_CODEX" -H "Content-Type: application/json" \
#     -d '{"model":"gpt-5.5","stream":true,"input":"hi"}' | grep response.completed
# The output should include a response.output[] item missing id/status - and
# after this patch, goose should accept it instead of erroring.
#
# If upstream goose ever makes these fields `Option<String>` or adds
# `#[serde(default)]` itself, this patch can be dropped.

diff --git a/crates/goose/src/providers/formats/openai_responses.rs b/crates/goose/src/providers/formats/openai_responses.rs
index e89cd89..ef84ba1 100644
--- a/crates/goose/src/providers/formats/openai_responses.rs
+++ b/crates/goose/src/providers/formats/openai_responses.rs
@@ -316,17 +316,23 @@ pub enum ResponseOutputItemInfo {
         summary: Vec<SummaryText>,
     },
     Message {
+        #[serde(default)]
         id: String,
+        #[serde(default)]
         status: String,
         role: String,
         content: Vec<ContentPart>,
     },
     FunctionCall {
+        #[serde(default)]
         id: String,
+        #[serde(default)]
         status: String,
         #[serde(skip_serializing_if = "Option::is_none")]
         call_id: Option<String>,
+        #[serde(default)]
         name: String,
+        #[serde(default)]
         arguments: String,
     },
 }
