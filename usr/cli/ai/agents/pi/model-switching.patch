+  async setSessionConfigOption(params: SetSessionConfigOptionRequest): Promise<SetSessionConfigOptionResponse> {
+    const session = this.sessions.get(params.sessionId)
+
+    if (params.configId === 'model') {
+      const modelId = String(params.value)
+
+      let provider: string | null = null
+      let model: string | null = null
+
+      if (modelId.includes('/')) {
+        const [p, ...rest] = modelId.split('/')
+        provider = p
+        model = rest.join('/')
+      } else {
+        // Resolve provider from available models
+        const data = (await session.proc.getAvailableModels()) as any
+        const models: any[] = Array.isArray(data?.models) ? data.models : []
+        const found = models.find((m: any) => String(m?.id) === modelId)
+        if (found) {
+          provider = String(found.provider)
+          model = String(found.id)
+        }
+      }
+
+      if (!provider || !model) {
+        throw RequestError.invalidParams(`Unknown model: ${modelId}`)
+      }
+
+      await session.proc.setModel(provider, model)
+
+      // Re-fetch models to return updated configOptions
+      const updatedModels = await getModelState(session.proc)
+      return { configOptions: updatedModels ? buildModelConfigOptions(updatedModels) : [] }
+    }
+
+    throw RequestError.invalidParams(`Unknown configId: ${params.configId}`)
+  }
+
