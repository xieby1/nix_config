# Patch: ship plugin.yaml manifests in packaged Hermes wheels
#
# Root cause:
#   Hermes plugin discovery only loads directory plugins that contain
#   plugin.yaml/plugin.yml. The v2026.5.16 Python package installed by the
#   Home Manager/Nix build included plugins/web/*/__init__.py and provider.py
#   files, but omitted plugin.yaml package data. As a result bundled web
#   providers (tavily, firecrawl, exa, etc.) were never registered and
#   web_search returned "No web search provider configured" despite a valid
#   TAVILY_API_KEY.
#
# Upstream context:
#   - Issue: NousResearch/hermes-agent#28149
#   - Related PRs: #28162, #28170 (ship plugin manifests in wheel/sdist)
#
# Rebase notes:
#   Generated against upstream tag v2026.5.16, which is the hermes-agent pin
#   used by the current llm-agents.nix package. Remove this patch once the
#   pinned package includes equivalent package-data entries upstream.
#
# Regenerate:
#   cd ~/Codes/hermes-agent
#   git checkout v2026.5.16
#   edit pyproject.toml [tool.setuptools.package-data]
#   git diff > ~/.config/nixpkgs/usr/cli/ai/hermes/package-plugin-manifests.patch
#
diff --git a/pyproject.toml b/pyproject.toml
index ba66d0da7..b12dec6de 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -212,6 +212,15 @@ py-modules = ["run_agent", "model_tools", "toolsets", "batch_runner", "trajector
 [tool.setuptools.package-data]
 hermes_cli = ["web_dist/**/*"]
 gateway = ["assets/**/*"]
+plugins = [
+  "*/plugin.yaml",
+  "*/*/plugin.yaml",
+  "*/plugin.yml",
+  "*/*/plugin.yml",
+  "*/dashboard/manifest.json",
+  "*/dashboard/dist/*",
+  "*/dashboard/dist/**/*",
+]
 
 [tool.setuptools.packages.find]
 include = ["agent", "agent.*", "tools", "tools.*", "hermes_cli", "gateway", "gateway.*", "tui_gateway", "tui_gateway.*", "cron", "acp_adapter", "plugins", "plugins.*", "providers", "providers.*"]
