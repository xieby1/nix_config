@@ -0,0 +1,190 @@
+"""Regression tests for remembering session-only /model switches."""
+
+import importlib
+from pathlib import Path
+from types import SimpleNamespace
+from unittest.mock import MagicMock, patch
+
+import pytest
+import yaml
+
+
+@pytest.fixture
+def isolated_hermes_home(tmp_path, monkeypatch):
+    hermes_home = tmp_path / ".hermes"
+    hermes_home.mkdir()
+    monkeypatch.setenv("HERMES_HOME", str(hermes_home))
+    monkeypatch.setattr(Path, "home", lambda: tmp_path)
+    return hermes_home
+
+
+def write_config(hermes_home: Path, data: dict) -> Path:
+    config_path = hermes_home / "config.yaml"
+    config_path.write_text(yaml.safe_dump(data), encoding="utf-8")
+    return config_path
+
+
+def read_config(hermes_home: Path) -> dict:
+    return yaml.safe_load((hermes_home / "config.yaml").read_text(encoding="utf-8")) or {}
+
+
+def test_cli_session_model_switch_records_last_used_without_changing_default(isolated_hermes_home, monkeypatch):
+    write_config(
+        isolated_hermes_home,
+        {
+            "model": {"default": "configured-default", "provider": "openrouter"},
+            "display": {"skin": "default"},
+            "agent": {},
+        },
+    )
+    import cli
+
+    monkeypatch.setattr(cli, "_cprint", lambda *args, **kwargs: None)
+    switch_result = MagicMock(
+        success=True,
+        new_model="anthropic/claude-sonnet-4",
+        target_provider="anthropic",
+        provider_changed=True,
+        api_key="",
+        base_url="",
+        api_mode="anthropic_messages",
+        provider_label="Anthropic",
+        model_info=None,
+        warning_message="",
+    )
+    cli_obj = cli.HermesCLI.__new__(cli.HermesCLI)
+    cli_obj.model = "configured-default"
+    cli_obj.provider = "openrouter"
+    cli_obj.requested_provider = "openrouter"
+    cli_obj.api_key = ""
+    cli_obj.base_url = ""
+    cli_obj.api_mode = "chat_completions"
+    cli_obj.agent = None
+
+    cli.HermesCLI._apply_model_switch_result(cli_obj, switch_result, persist_global=False)
+
+    model_cfg = read_config(isolated_hermes_home)["model"]
+    assert model_cfg["default"] == "configured-default"
+    assert model_cfg["provider"] == "openrouter"
+    assert model_cfg["last_used_model"] == "anthropic/claude-sonnet-4"
+    assert model_cfg["last_used_provider"] == "anthropic"
+
+
+def test_cli_startup_prefers_last_used_model_over_config_default(isolated_hermes_home, monkeypatch):
+    import cli
+
+    monkeypatch.setattr(
+        cli,
+        "CLI_CONFIG",
+        {
+            "model": {
+                "default": "configured-default",
+                "provider": "openrouter",
+                "last_used_model": "anthropic/claude-sonnet-4",
+                "last_used_provider": "anthropic",
+            },
+            "display": {},
+            "agent": {},
+            "checkpoints": {},
+        },
+    )
+    monkeypatch.setattr(cli, "_configure_output_history", lambda **kwargs: None)
+    cli_obj = cli.HermesCLI(model=None, compact=True)
+
+    assert cli_obj.model == "anthropic/claude-sonnet-4"
+    assert cli_obj.requested_provider == "anthropic"
+    assert cli_obj._model_is_default is False
+
+
+def test_oneshot_uses_last_used_model_before_config_default(isolated_hermes_home, monkeypatch):
+    write_config(
+        isolated_hermes_home,
+        {
+            "model": {
+                "default": "configured-default",
+                "provider": "openrouter",
+                "last_used_model": "anthropic/claude-sonnet-4",
+                "last_used_provider": "anthropic",
+            },
+            "tools": {"platforms": {"cli": []}},
+        },
+    )
+    import hermes_cli.oneshot as oneshot
+
+    captured = {}
+
+    class FakeAgent:
+        def __init__(self, **kwargs):
+            captured.update(kwargs)
+            self.suppress_status_output = False
+            self.stream_delta_callback = object()
+            self.tool_gen_callback = object()
+
+        def chat(self, prompt):
+            return "ok"
+
+    monkeypatch.delenv("HERMES_INFERENCE_MODEL", raising=False)
+    monkeypatch.delenv("HERMES_INFERENCE_PROVIDER", raising=False)
+    monkeypatch.setattr("hermes_cli.runtime_provider.resolve_runtime_provider", lambda **kwargs: {"provider": kwargs.get("requested"), "api_key": "k", "base_url": "u", "api_mode": "chat_completions"})
+    monkeypatch.setattr("run_agent.AIAgent", FakeAgent)
+
+    assert oneshot._run_agent("hello", use_config_toolsets=False) == "ok"
+    assert captured["model"] == "anthropic/claude-sonnet-4"
+    assert captured["provider"] == "anthropic"
+
+
+def test_tui_resolve_model_prefers_last_used_model(isolated_hermes_home, monkeypatch):
+    write_config(
+        isolated_hermes_home,
+        {
+            "model": {
+                "default": "configured-default",
+                "provider": "openrouter",
+                "last_used_model": "anthropic/claude-sonnet-4",
+                "last_used_provider": "anthropic",
+            }
+        },
+    )
+    monkeypatch.delenv("HERMES_MODEL", raising=False)
+    monkeypatch.delenv("HERMES_INFERENCE_MODEL", raising=False)
+    import tui_gateway.server as server
+
+    server = importlib.reload(server)
+    assert server._resolve_model() == "anthropic/claude-sonnet-4"
+    assert server._resolve_startup_runtime() == ("anthropic/claude-sonnet-4", "anthropic")
+
+
+def test_tui_session_model_switch_records_last_used_without_changing_default(isolated_hermes_home, monkeypatch):
+    write_config(
+        isolated_hermes_home,
+        {
+            "model": {"default": "configured-default", "provider": "openrouter"},
+        },
+    )
+    import tui_gateway.server as server
+
+    server = importlib.reload(server)
+    result = SimpleNamespace(
+        new_model="anthropic/claude-sonnet-4",
+        target_provider="anthropic",
+        base_url="https://api.anthropic.example/v1",
+    )
+
+    server._persist_model_switch(result, persist_global=False)
+
+    model_cfg = read_config(isolated_hermes_home)["model"]
+    assert model_cfg["default"] == "configured-default"
+    assert model_cfg["provider"] == "openrouter"
+    assert model_cfg["last_used_model"] == "anthropic/claude-sonnet-4"
+    assert model_cfg["last_used_provider"] == "anthropic"
+    assert "base_url" not in model_cfg
+
+
+def test_auxiliary_main_model_falls_back_to_last_used(isolated_hermes_home):
+    write_config(
+        isolated_hermes_home,
+        {"model": {"default": "", "last_used_model": "anthropic/claude-sonnet-4"}},
+    )
+    import agent.auxiliary_client as auxiliary_client
+
+    assert auxiliary_client._read_main_model() == "anthropic/claude-sonnet-4"
