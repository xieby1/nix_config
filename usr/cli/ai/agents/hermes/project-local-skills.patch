# === PATCH 2/2 NOTES ===
# This is a LOCAL addition, not from the upstream PR.
# It fixes two issues found during testing:
#
# 1. Stale TERMINAL_CWD: the env var can be leftover from a previous
#    terminal-tool `cd` session, pointing to a non-git directory.
#    _resolve_cwd now gates env-var CWDs on git-repo membership;
#    os.getcwd() wins when env vars are stale.  This is the main fix.
#
# 2. Missing .agents/skills directory: the original PR only discovered
#    .hermes/skills and .ai/skills.  Added .agents/skills (first in
#    precedence) because this user's project skills live there.
#
# If upstream later adds similar CWD handling or .agents/skills
# discovery, this whole commit can be dropped.

diff --git a/agent/skill_utils.py b/agent/skill_utils.py
index bc30e9a0c..987c26a79 100644
--- a/agent/skill_utils.py
+++ b/agent/skill_utils.py
@@ -173,14 +173,36 @@ def _normalize_string_set(values) -> Set[str]:
 
 
 def _resolve_cwd(cwd: Optional[os.PathLike | str] = None) -> Path:
-    """Return the session working directory used for project-local discovery."""
-    raw_cwd = (
-        cwd
-        or os.getenv("TERMINAL_CWD")
-        or os.getenv("HERMES_CWD")
-        or os.getcwd()
-    )
-    return Path(raw_cwd).expanduser().resolve()
+    """Return the session working directory used for project-local discovery.
+
+    Prefers ``TERMINAL_CWD`` / ``HERMES_CWD`` when they lead to a git repo;
+    falls back to ``os.getcwd()`` otherwise, so stale env vars from a
+    previous terminal-tool session don't shadow the actual shell CWD.
+    """
+    env_candidates: List[Optional[str]] = []
+    if cwd is not None:
+        env_candidates.append(str(cwd))
+    else:
+        for var in ("TERMINAL_CWD", "HERMES_CWD"):
+            v = os.getenv(var)
+            if v:
+                env_candidates.append(v)
+    env_candidates.append(os.getcwd())
+
+    # Try env-var CWDs first, but only accept them if they are inside a git
+    # repo (or are themselves a git repo).  If none qualify, use os.getcwd().
+    for i, raw in enumerate(env_candidates):
+        candidate = Path(raw).expanduser().resolve()
+        is_last = (i == len(env_candidates) - 1)
+        if is_last:
+            return candidate  # os.getcwd() always wins on last try
+        # Accept env-var CWD only if it sits inside a git repo
+        if (candidate / ".git").exists():
+            return candidate
+        for parent in candidate.parents:
+            if (parent / ".git").exists():
+                return candidate
+    return Path(env_candidates[-1]).expanduser().resolve()
 
 
 def _find_project_root(cwd: Optional[os.PathLike | str] = None) -> Path:
@@ -214,12 +236,17 @@ def get_project_skills_dirs(cwd: Optional[os.PathLike | str] = None) -> List[Pat
     A git root is used when available.  Existing directories are returned in
