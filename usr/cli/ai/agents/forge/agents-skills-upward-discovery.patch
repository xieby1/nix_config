+    /// Returns all `.agents/skills` directory paths discovered by walking from
+    /// cwd up through all parent directories to `/`.
+    ///
+    /// The returned paths are ordered from the root-most ancestor to the
+    /// current working directory, so that skills loaded later (closer to cwd)
+    /// take precedence when conflicts are resolved.
+    pub fn agents_skills_paths(&self) -> Vec<PathBuf> {
+        let mut paths = Vec::new();
+        let mut current = Some(self.cwd.as_path());
+
+        while let Some(dir) = current {
+            let agents_dir = dir.join(".agents/skills");
+            paths.push(agents_dir);
+            current = dir.parent();
+        }
+
+        paths.reverse();
+
+        // Also include home .agents/skills if not already in the path
+        if let Some(home) = &self.home {
+            let home_agents = home.join(".agents/skills");
+            if !paths.contains(&home_agents) {
+                paths.push(home_agents);
+            }
+        }
+
+        paths
+    }
+
     /// Returns the project-local skills directory path (.forge/skills)
     pub fn local_skills_path(&self) -> PathBuf {
         self.cwd.join(".forge/skills")
@@ -380,4 +409,56 @@ mod tests {
 
         assert_eq!(actual, expected);
     }
+
+    #[test]
+    fn test_agents_skills_paths_walks_up_from_cwd() {
+        let fixture: Environment = Faker.fake();
+        let fixture = fixture
+            .cwd(PathBuf::from("/home/user/project"))
+            .home(PathBuf::from("/home/user"));
+
+        let actual = fixture.agents_skills_paths();
+
+        let expected = vec![
+            PathBuf::from("/.agents/skills"),
+            PathBuf::from("/home/.agents/skills"),
+            PathBuf::from("/home/user/.agents/skills"),
+            PathBuf::from("/home/user/project/.agents/skills"),
+        ];
+        assert_eq!(actual, expected);
+    }
+
+    #[test]
+    fn test_agents_skills_paths_includes_home_when_not_on_cwd_path() {
+        let fixture: Environment = Faker.fake();
+        let fixture = fixture
+            .cwd(PathBuf::from("/tmp/project"))
+            .home(PathBuf::from("/home/user"));
+
+        let actual = fixture.agents_skills_paths();
+
+        let expected = vec![
+            PathBuf::from("/.agents/skills"),
+            PathBuf::from("/tmp/.agents/skills"),
+            PathBuf::from("/tmp/project/.agents/skills"),
+            PathBuf::from("/home/user/.agents/skills"),
+        ];
+        assert_eq!(actual, expected);
+    }
+
+    #[test]
+    fn test_agents_skills_paths_dedupes_home_when_on_cwd_path() {
+        let fixture: Environment = Faker.fake();
+        let fixture = fixture
+            .cwd(PathBuf::from("/home/user/project"))
+            .home(PathBuf::from("/home/user"));
+
+        let actual = fixture.agents_skills_paths();
+
+        let home_count = actual
+            .iter()
+            .filter(|p| **p == PathBuf::from("/home/user/.agents/skills"))
+            .count();
+        assert_eq!(home_count, 1);
+    }
 }
