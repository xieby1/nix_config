index c50faf5..2f2e558 100644
--- a/internal/providers/responses_adapter.go
+++ b/internal/providers/responses_adapter.go
@@ -74,11 +74,27 @@ func normalizeResponsesToolsForChat(tools []map[string]any) []map[string]any {
 
 	normalized := make([]map[string]any, 0, len(tools))
 	for _, tool := range tools {
+		if shouldDropResponsesToolForChat(tool) {
+			continue
+		}
 		normalized = append(normalized, normalizeResponsesToolForChat(tool))
 	}
+	if len(normalized) == 0 {
+		return nil
+	}
 	return normalized
 }
 
+// shouldDropResponsesToolForChat removes Responses hosted/server tools before
+// adapting a request to Chat Completions. Chat-style upstreams expect ordinary
+// JSON-schema function tools only; forwarding hosted tool advertisements such
+// as web_search_preview, file_search, or container makes non-OpenAI providers
+// reject the request even though the gateway cannot execute those hosted tools.
+func shouldDropResponsesToolForChat(tool map[string]any) bool {
+	toolType, _ := tool["type"].(string)
+	return strings.TrimSpace(toolType) != "" && strings.TrimSpace(toolType) != "function"
+}
