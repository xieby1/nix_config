+    @pytest.mark.asyncio
+    async def test_new_session_returns_config_options_for_codecompanion(self):
+        """configOptions must be populated so codecompanion.nvim can switch models via ga."""
+        from acp.schema import SessionConfigOptionSelect
+
+        manager = SessionManager(
+            agent_factory=lambda: SimpleNamespace(model="gpt-5.4", provider="openai-codex")
+        )
+        acp_agent = HermesACPAgent(session_manager=manager)
+
+        with patch(
+            "hermes_cli.models.curated_models_for_provider",
+            return_value=[("gpt-5.4", "recommended"), ("gpt-5.4-mini", "")],
+        ):
+            resp = await acp_agent.new_session(cwd="/tmp")
+
+        assert resp.config_options is not None
+        assert len(resp.config_options) == 1
+        opt = resp.config_options[0]
+        assert isinstance(opt, SessionConfigOptionSelect)
+        assert opt.id == "model"
+        assert opt.type == "select"
+        assert opt.category == "model"
+        assert opt.name == "Model"
+        assert opt.current_value == "openai-codex:gpt-5.4"
+        assert len(opt.options) == 2
+        assert opt.options[0].name == "gpt-5.4"
+        assert opt.options[0].value == "openai-codex:gpt-5.4"
+        assert opt.options[1].name == "gpt-5.4-mini"
+        assert opt.options[1].value == "openai-codex:gpt-5.4-mini"
+
