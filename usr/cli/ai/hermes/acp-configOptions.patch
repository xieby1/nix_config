+    def _build_config_options(self, state: SessionState) -> list[SessionConfigOptionSelect] | None:
+        """Build ACP configOptions for model switching (used by codecompanion.nvim).
+
+        Unlike ``_build_model_state`` which only returns models for the current
+        provider, this includes models from *all configured* providers so that the
+        user can switch both provider and model from a single picker (matching the
+        UX of Hermes' ``/model`` command).
+
+        Improvements:
+        1. Display format: ``<provider-label>:<model-name>`` for clarity
+        2. Filter to configured providers only (env vars, auth store, credential pool)
+        3. INFO-level logging of served provider:model combinations
+        """
+        model = str(state.model or getattr(state.agent, "model", "") or "").strip()
+        current_provider = getattr(state.agent, "provider", None) or detect_provider() or "openrouter"
+
+        try:
+            from hermes_cli.models import (
+                CANONICAL_PROVIDERS,
+                curated_models_for_provider,
+                normalize_provider,
+                provider_label,
+            )
+            from hermes_cli.auth import PROVIDER_REGISTRY
+            from hermes_cli.providers import HERMES_OVERLAYS
+
+            current_normalized = normalize_provider(current_provider)
+            current_model_id = self._encode_model_choice(current_normalized, model)
+
+            options: list[SessionConfigSelectOption] = []
+            seen_ids: set[str] = set()
+            served_providers: set[str] = set()
+
+            def _provider_has_credentials(provider_slug: str) -> bool:
+                """Check if a provider has credentials configured (env, auth store, pool)."""
+                # 1. Check env vars from PROVIDER_REGISTRY
+                pcfg = PROVIDER_REGISTRY.get(provider_slug)
+                if pcfg and pcfg.api_key_env_vars:
+                    if any(os.environ.get(ev) for ev in pcfg.api_key_env_vars):
+                        return True
+
+                # 2. Check HERMES_OVERLAYS for extra_env_vars
+                overlay = HERMES_OVERLAYS.get(provider_slug)
+                if overlay and overlay.extra_env_vars:
+                    if any(os.environ.get(ev) for ev in overlay.extra_env_vars):
+                        return True
+
+                # 3. Check auth store
+                try:
+                    from hermes_cli.auth import _load_auth_store
+                    store = _load_auth_store()
+                    if store and provider_slug in (store.get("providers") or {}):
+                        return True
+                except Exception:
+                    pass
+
+                # 4. Check credential pool
+                try:
+                    from agent.credential_pool import load_pool
+                    pool = load_pool(provider_slug)
+                    if pool.has_credentials():
+                        return True
+                except Exception:
+                    pass
+
+                # 5. Special case: AWS SDK (bedrock)
+                if pcfg and getattr(pcfg, "auth_type", "") == "aws_sdk":
+                    try:
+                        from agent.bedrock_adapter import has_aws_credentials
+                        return bool(has_aws_credentials())
+                    except Exception:
+                        pass
+
+                # 6. Special case: anthropic — check external credential files
+                if provider_slug == "anthropic":
+                    try:
+                        from agent.anthropic_adapter import (
+                            read_claude_code_credentials,
+                            read_hermes_oauth_credentials,
+                        )
+                        hermes_creds = read_hermes_oauth_credentials()
+                        cc_creds = read_claude_code_credentials()
+                        if (hermes_creds and hermes_creds.get("accessToken")) or \
+                           (cc_creds and cc_creds.get("accessToken")):
+                            return True
+                    except Exception:
+                        pass
+
+                # 7. LM Studio — check LM_BASE_URL or LM_API_KEY
+                if provider_slug == "lmstudio":
+                    if os.environ.get("LM_API_KEY") or os.environ.get("LM_BASE_URL"):
+                        return True
+
+                return False
+
+            def _add_model(provider_slug: str, model_id: str, description: str = "", is_current: bool = False) -> None:
+                choice_id = self._encode_model_choice(provider_slug, model_id)
+                if choice_id in seen_ids:
+                    return
+                provider_name = provider_label(provider_slug)
+                display_name = f"{provider_name}: {model_id}"
+                desc_parts = []
+                if description:
+                    desc_parts.append(str(description).strip())
+                if is_current:
+                    desc_parts.append("current")
+                options.append(
+                    SessionConfigSelectOption(
+                        name=display_name,
+                        value=choice_id,
+                        description=" • ".join(part for part in desc_parts if part) or None,
+                    )
+                )
+                seen_ids.add(choice_id)
+                served_providers.add(provider_slug)
+
+            # 1. Add current model first (so it appears at the top)
+            if current_model_id:
+                _add_model(current_normalized, model, is_current=True)
+
+            # 2. Add models from all *configured* providers
+            for entry in CANONICAL_PROVIDERS:
+                provider_slug = entry.slug
+                if not _provider_has_credentials(provider_slug):
+                    continue
+                try:
+                    models = curated_models_for_provider(provider_slug)
+                    if not models:
+                        continue
+                    for model_id, description in models:
+                        rendered = str(model_id or "").strip()
+                        if not rendered:
+                            continue
+                        _add_model(provider_slug, rendered, description, is_current=False)
+                except Exception:
+                    logger.debug("Could not fetch models for provider %s", provider_slug, exc_info=True)
+                    continue
+
+            if not options:
+                logger.info("ACP configOptions: no configured providers found, falling back to current provider only")
+                return None
+
+            logger.info(
+                "ACP configOptions: serving %d model(s) from %d provider(s): %s",
+                len(options),
+                len(served_providers),
+                ", ".join(sorted(served_providers)),
+            )
+
+            return [
+                SessionConfigOptionSelect(
+                    id="model",
+                    type="select",
+                    name="Model",
+                    category="model",
+                    current_value=current_model_id or options[0].value,
+                    options=options,
+                )
+            ]
+        except Exception:
+            logger.debug("Could not build ACP config options", exc_info=True)
+
+        # Fallback: delegate to _build_model_state for single-provider list
+        model_state = self._build_model_state(state)
+        if not model_state:
+            return None
+
+        fallback_options = [
+            SessionConfigSelectOption(
+                name=info.name,
+                value=info.model_id,
+                description=info.description,
+            )
+            for info in model_state.available_models
+        ]
+        if not fallback_options:
+            return None
+
+        return [
+            SessionConfigOptionSelect(
+                id="model",
+                type="select",
+                name="Model",
+                category="model",
+                current_value=model_state.current_model_id,
+                options=fallback_options,
+            )
+        ]
+
     @staticmethod
     def _resolve_model_selection(raw_model: str, current_provider: str) -> tuple[str, str]:
         """Resolve ``provider:model`` input into the provider and normalized model id."""
@@ -656,6 +847,7 @@ class HermesACPAgent(acp.Agent):
         return NewSessionResponse(
             session_id=state.session_id,
             models=self._build_model_state(state),
+            config_options=self._build_config_options(state),
         )
 
     def _schedule_history_replay(self, state: SessionState) -> None:
@@ -686,7 +878,10 @@ class HermesACPAgent(acp.Agent):
         self._schedule_history_replay(state)
         self._schedule_available_commands_update(session_id)
         self._schedule_usage_update(state)
-        return LoadSessionResponse(models=self._build_model_state(state))
+        return LoadSessionResponse(
+            models=self._build_model_state(state),
+            config_options=self._build_config_options(state),
+        )
 
     async def resume_session(
         self,
@@ -704,7 +899,10 @@ class HermesACPAgent(acp.Agent):
         self._schedule_history_replay(state)
         self._schedule_available_commands_update(state.session_id)
         self._schedule_usage_update(state)
-        return ResumeSessionResponse(models=self._build_model_state(state))
+        return ResumeSessionResponse(
+            models=self._build_model_state(state),
+            config_options=self._build_config_options(state),
+        )
 
     async def cancel(self, session_id: str, **kwargs: Any) -> None:
         state = self.session_manager.get_session(session_id)
@@ -1412,17 +1610,51 @@ class HermesACPAgent(acp.Agent):
     async def set_config_option(
         self, config_id: str, session_id: str, value: str, **kwargs: Any
     ) -> SetSessionConfigOptionResponse | None:
-        """Accept ACP config option updates even when Hermes has no typed ACP config surface yet."""
+        """Handle ACP config option updates.
+
+        When ``config_id == "model"``, this actually switches the model (and
+        potentially the provider) by re-creating the agent — matching the
+        behaviour of ``set_session_model``.  Other config IDs are stored
+        opaquely for future use.
+        """
         state = self.session_manager.get_session(session_id)
         if state is None:
             logger.warning("Session %s: config update requested for missing session", session_id)
             return None
 
+        # Persist the raw option value
         options = getattr(state, "config_options", None)
         if not isinstance(options, dict):
             options = {}
         options[str(config_id)] = value
         setattr(state, "config_options", options)
+
+        # When the model selector changes, actually switch the model
+        if str(config_id) == "model":
+            current_provider = getattr(state.agent, "provider", None)
+            requested_provider, resolved_model = self._resolve_model_selection(
+                value,
+                current_provider or "openrouter",
+            )
+            state.model = resolved_model
+            provider_changed = bool(current_provider and requested_provider != current_provider)
+            current_base_url = None if provider_changed else getattr(state.agent, "base_url", None)
+            current_api_mode = None if provider_changed else getattr(state.agent, "api_mode", None)
+            state.agent = self.session_manager._make_agent(
+                session_id=session_id,
+                cwd=state.cwd,
+                model=resolved_model,
+                requested_provider=requested_provider,
+                base_url=current_base_url,
+                api_mode=current_api_mode,
+            )
+            logger.info(
+                "Session %s: model switched to %s via provider %s (via config option)",
+                session_id,
+                resolved_model,
+                requested_provider,
+            )
+
         self.session_manager.save_session(session_id)
         logger.info("Session %s: config option %s updated", session_id, config_id)
         return SetSessionConfigOptionResponse(config_options=[])

